# Copy to .env.mirror and fill in. Only the ingestion daemon needs these
# (it mirrors events from the prod VEX hub); the API server does not.

VEX_PROD_API_BASE=https://inviteinstitutehub.org
PROD_USERNAME=
PROD_PASSWORD=

# Optional overrides
# DB_PATH=db.sqlite3
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# PIPELINE_INTERVAL=0.5
# PIPELINE_PAGE_LIMIT=500
